{
    "name": "bnomei/scip-laravel",
    "description": "Laravel-aware SCIP index generation for Laravel applications.",
    "homepage": "https://github.com/bnomei/scip-laravel",
    "type": "library",
    "keywords": [
        "laravel",
        "scip",
        "sourcegraph",
        "codeintel",
        "code-intelligence",
        "code-navigation",
        "go-to-definition",
        "indexer",
        "static-analysis",
        "livewire",
        "inertia"
    ],
    "license": "MIT",
    "support": {
        "issues": "https://github.com/bnomei/scip-laravel/issues",
        "source": "https://github.com/bnomei/scip-laravel"
    },
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "composer-runtime-api": "^2.2",
        "composer/class-map-generator": "^1.0",
        "google/protobuf": "^4.26",
        "jetbrains/phpstorm-stubs": "^2024.1",
        "laravel/ranger": "^0.1.9",
        "laravel/surveyor": "^0.1.9",
        "nikic/php-parser": "^5.0",
        "phpstan/phpdoc-parser": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Bnomei\\ScipLaravel\\": "src/",
            "GPBMetadata\\": "packages/scip-php/src/Bindings/GPBMetadata/",
            "Scip\\": "packages/scip-php/src/Bindings/Scip/",
            "ScipPhp\\": "packages/scip-php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bnomei\\ScipLaravel\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/scip-laravel"
    ],
    "scripts": {
        "analyze": "mago analyze",
        "format": "mago format",
        "format:check": "mago format --check",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "see-also": [
            {
                "name": "bnomei/frigg",
                "url": "https://github.com/bnomei/frigg",
                "description": "Frigg can consume the generated Laravel-aware SCIP index from this package."
            }
        ]
    },
    "prefer-stable": true
}
